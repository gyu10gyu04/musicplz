# PostgreSQL 접속 문자열 (로컬 또는 Render)
DATABASE_URL=postgresql://user:password@localhost:5432/musicplz

# 임의의 무작위 문자열 (세션 암호화용)
SESSION_SECRET=여기에-랜덤-문자열-입력

# Spotify Developer Dashboard → 앱 생성 → Basic Information
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google AI Studio → Get API key
GEMINI_API_KEY=

# Cloudflare Turnstile CAPTCHA (선택, 설정하면 로그인/회원가입에서 보안 확인 필수)
# https://dash.cloudflare.com/?to=/:account/turnstile 에서 사이트 생성 후 발급
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend 이메일 인증 (회원가입 이메일 인증용)
# https://resend.com 에서 API 키 발급, EMAIL_FROM은 인증된 도메인 주소 사용
RESEND_API_KEY=
EMAIL_FROM=MusicPlz <noreply@example.com>

# 배포된 서비스 주소 (인증 링크 생성용, 예: https://musicplz.onrender.com)
PUBLIC_BASE_URL=http://localhost:3000
