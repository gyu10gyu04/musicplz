# PostgreSQL 접속 문자열.
# - 로컬에 PostgreSQL을 직접 설치한 경우 예시: postgresql://postgres:비밀번호@localhost:5432/musicplz
# - Render의 PostgreSQL을 쓰는 경우: Render 대시보드 → 만든 PostgreSQL 인스턴스 → "Internal Database URL" 또는
#   "External Database URL" 값을 그대로 복사해서 넣어주세요.
DATABASE_URL=postgresql://postgres:password@localhost:5432/musicplz

# 세션 암호화에 쓰이는 비밀 키. 실제 운영 시에는 반드시 길고 무작위한 값으로 바꾸세요.
SESSION_SECRET=changeme

# 서버 포트
PORT=3000

# production으로 설정하면 secure 쿠키(HTTPS 전용)와 PostgreSQL SSL 연결이 활성화됩니다.
# 로컬 개발 중에는 비워두거나 development로 두세요.
NODE_ENV=development

# ── AI 음악 검색 기능에 필요한 키들 ──

# Spotify Developer Dashboard(developer.spotify.com/dashboard)에서 만든 앱의
# Client ID / Client Secret. "View client secret"을 눌러야 Secret 값이 보입니다.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google AI Studio(aistudio.google.com)에서 발급받은 Gemini API 키.
# 사용자 문장을 검색어로 해석하는 데 사용됩니다.
GEMINI_API_KEY=
